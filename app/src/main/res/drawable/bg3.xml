<?xml version="1.0" encoding="utf-8" ?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_pressed="true">
		<shape android:shape="rectangle">
			<stroke android:width="2.0dip" android:color="#ff001fe4" />
			<solid android:color="#ffbf004b" />
			<corners android:radius="100.0dip" />
		</shape>
		<transition android:autoMirrored="true" />
	</item>
	<item>
		<shape>
			<stroke android:width="2.0dip" android:color="#fff57c00" />
			<solid android:color="#ff001fe4" />
		</shape>
	</item>
</selector>
